// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL") // es: postgresql://postgres:password@localhost:5432/whistledb_TENANT
}

////////////////////////////////////////////////////
// ENUM
////////////////////////////////////////////////////
enum SubscriptionPlan {
  MENSILE
  SEMESTRALE
  ANNUALE
}

enum PaymentMethod {
  CARTA
  BONIFICO
}

enum EmployeeRange {
  DA_0_A_50
  DA_51_A_100
  DA_101_A_150
  DA_151_A_200
  DA_201_A_250
  OLTRE_250
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  SUSPENDED
  CLOSED
}

enum ReportChannel {
  WEB
  PHONE
  EMAIL
  OTHER
}

////////////////////////////////////////////////////
// MODELS
////////////////////////////////////////////////////

// Anagrafica del cliente (solo la sua)
model Client {
  id            String         @id @default(cuid())
  companyName   String
  contactEmail  String
  status        String         @default("ACTIVE")
  employeeRange EmployeeRange
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Abbonamenti del cliente
model Subscription {
  id        String           @id @default(cuid())
  clientId  String
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(10, 2)
  currency  String           @default("EUR")
  plan      SubscriptionPlan
  method    PaymentMethod
  status    String           @default("SUCCESS")
  createdAt DateTime         @default(now())
}

// Utenti interni del portale
model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String   @unique
  password  String // hash con bcrypt
  role      String // ADMIN, AGENT, USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports    WhistleReport[]       @relation("UserReports")
  messages   ReportMessage[]       @relation("UserMessages")
  statusLogs ReportStatusHistory[] @relation("UserStatusLogs")
}

// Segnalazioni
model WhistleReport {
  id             String        @id @default(cuid())
  tenantId       String
  publicCode     String        @unique
  secretHash     String
  status         ReportStatus  @default(OPEN)
  title          String
  summary        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deadline       DateTime?
  acknowledgeAt  DateTime?
  channel        ReportChannel @default(WEB)
  closedAt       DateTime?
  consentGivenAt DateTime?
  consentVersion String?
  dueAt          DateTime?
  locale         String?

  authorId String?
  author   User?   @relation("UserReports", fields: [authorId], references: [id])

  messages   ReportMessage[]
  statusLogs ReportStatusHistory[]
}

// Messaggi all’interno di una segnalazione
model ReportMessage {
  id        String   @id @default(cuid())
  tenantId  String
  reportId  String
  author    String
  body      String
  createdAt DateTime @default(now())

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  authorId String?
  user     User?   @relation("UserMessages", fields: [authorId], references: [id])
}

// Storico cambi di stato di un report
model ReportStatusHistory {
  id         String       @id @default(cuid())
  tenantId   String
  reportId   String
  note       String?
  author     String?
  agentId    String?
  modifiedAt DateTime     @default(now())
  status     ReportStatus

  report WhistleReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  agent  User?         @relation("UserStatusLogs", fields: [agentId], references: [id])
}
