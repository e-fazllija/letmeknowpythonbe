generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/public"
}

datasource db {
  provider = "postgresql"
  url      = env("PUBLIC_DATABASE_URL")
}

enum SubscriptionPlan {
  MENSILE
  SEMESTRALE
  ANNUALE
}

enum PaymentMethod {
  CARTA
  BONIFICO
}

enum EmployeeRange {
  DA_0_A_50
  DA_51_A_100
  DA_101_A_150
  DA_151_A_200
  DA_201_A_250
  OLTRE_250
}

model Client {
  id            String         @id @default(cuid())
  companyName   String         @unique // ragione sociale
  contactEmail  String         @unique // email principale
  status        String         @default("ACTIVE") // stato iscrizione
  employeeRange EmployeeRange
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id        String           @id @default(cuid())
  clientId  String
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount    Decimal          @db.Decimal(10, 2) // importo in euro
  currency  String           @default("EUR")
  plan      SubscriptionPlan
  method    PaymentMethod
  status    String           @default("SUCCESS") // SUCCESS, PENDING, FAILED
  createdAt DateTime         @default(now())
}
